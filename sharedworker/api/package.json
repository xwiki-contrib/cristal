{
  "name": "@xwiki/cristal-sharedworker-api",
  "version": "1.6.0-rc-1",
  "license": "LGPL 2.1",
  "author": "XWiki Org Community <contact@xwiki.org>",
  "homepage": "https://cristal.xwiki.org/",
  "repository": {
    "type": "git",
    "directory": "sharedworker/api",
    "url": "git+https://github.com/xwiki-contrib/cristal.git"
  },
  "bugs": {
    "url": "https://jira.xwiki.org/projects/CRISTAL/"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.*",
    "!src/**/*.test.*",
    "!src/**/__tests__"
  ],
  "scripts": {
    "api-extractor:local": "api-extractor run --local",
    "build": "rimraf dist && tsc --project tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint \"./src/**/*.{ts,tsx,vue}\" --max-warnings=0"
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "reflect-metadata": "0.x"
  },
  "devDependencies": {
    "@xwiki/cristal-dev-config": "workspace:*",
    "@xwiki/platform-tool-apiextractorconfig": "catalog:",
    "@xwiki/platform-tool-tsconfig": "catalog:",
    "typescript": "catalog:"
  }
}
