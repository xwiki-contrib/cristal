    "outDir": "dist/cjs",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": false,
    "resolveJsonModule": true
  },
  "extends": "../tsconfig.json",
  "include": [
    "./src/index.ts",
    "./src/**/*"
